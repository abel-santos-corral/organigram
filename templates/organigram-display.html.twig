{#
 * @file organigram-display.html.twig
 *
 * Default template for the organigram display. Used as fallback when no
 * renderer-specific override exists.
 *
 * To override per renderer, create in your theme:
 *   organigram-display--[plugin_id].html.twig   (e.g. organigram-display--d3.html.twig)
 *
 * Available variables:
 *   - root_node_id: NID of the root organigram node.
 *   - plugin_id:    Active renderer plugin ID (e.g. 'd3').
 *   - settings:     Renderer-specific settings array.
#}
<div id="organigram-container"
     class="organigram"
     data-root-id="{{ root_node_id }}"
     aria-label="{{ 'Organisational chart'|t }}"
     role="region">
  <p class="organigram__loading js-organigram-loading">
    {{ 'Loading organigram…'|t }}
  </p>
</div>
