<?php

/**
 * @file
 * Organigram module — Organigram node CT, Paragraph type, and D3 renderer.
 */

use Drupal\Core\Cache\Cache;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;

/**
 * Implements hook_theme().
 */
function organigram_theme(): array {
  return [
    'organigram_display' => [
      'variables' => [
        'root_node_id' => NULL,
        'settings'     => [],
        'plugin_id'    => NULL,
      ],
      'template' => 'organigram-display',
    ],
  ];
}

/**
 * Implements hook_theme_suggestions_HOOK_alter() for organigram_display.
 *
 * Adds a renderer-specific suggestion so themes can override the template
 * per renderer without touching the default.
 *
 * Example: to override the D3 renderer output, create
 * organigram-display--d3.html.twig in your theme's templates directory.
 */
function organigram_theme_suggestions_organigram_display_alter(
  array &$suggestions,
  array $variables,
): void {
  if (!empty($variables['plugin_id'])) {
    $suggestions[] = 'organigram_display__' . $variables['plugin_id'];
  }
}

/**
 * Implements hook_theme_suggestions_block_alter().
 *
 * Adds a renderer-specific suggestion to the organigram_block Drupal block so
 * themes can target the entire block wrapper per active renderer.
 *
 * Suggestion order (most specific last, Drupal picks the most specific):
 *   block
 *   block__organigram_block
 *   block__organigram_block__[renderer]   <- added here, e.g. __d3
 *
 * Usage in a theme: create block--organigram-block--d3.html.twig.
 * Usage in a module: implement hook_theme_suggestions_block_alter() and
 * append further suggestions as needed.
 */
function organigram_theme_suggestions_block_alter(
  array &$suggestions,
  array $variables,
): void {
  if (($variables['elements']['#plugin_id'] ?? '') !== 'organigram_block') {
    return;
  }

  $active_renderer = \Drupal::config('organigram.settings')->get('active_renderer');
  if (!empty($active_renderer)) {
    $suggestions[] = 'block__organigram_block__' . $active_renderer;
  }
}

/**
 * Implements hook_node_access_records_alter().
 *
 * Nothing custom needed — the module relies on core node access.
 */

/**
 * Implements hook_form_FORM_ID_alter().
 */
function organigram_form_node_organigram_node_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return;
  }

  if (
    isset($form['field_organigram_node_type']['widget']) &&
    \Drupal::entityTypeManager()->getStorage('organigram_node_type')->loadMultiple() === []
  ) {
    $form['field_organigram_node_type']['widget']['#description'] = t(
      'No Organigram Node Types defined yet. <a href=":url">Add a Organigram Node Type</a>.',
      [':url' => Url::fromRoute('entity.organigram_node_type.add_form')->toString()]
    );
  }

  // When Vacant is checked, hide person-specific fields.
  $vacant_selector = ':input[name="field_is_vacant[value]"]';
  foreach ([
    'field_responsible_name',
    'field_responsible_photo',
    'field_cv_document',
    'field_declaration_interest',
  ] as $field_name) {
    if (isset($form[$field_name])) {
      $form[$field_name]['#states']['invisible'][$vacant_selector] = ['checked' => TRUE];
    }
  }

  // When Enable modal is unchecked, hide all modal-dependent fields.
  // These fields are only meaningful when the detail modal is shown.
  $enable_modal_selector = ':input[name="field_enable_modal[value]"]';
  foreach ([
    'field_start_date',
    'field_end_date',
    'field_scope_of_works_title',
    'field_scope_of_work',
    'field_relation_type',
    'field_is_vacant',
    'field_responsible_name',
    'field_responsible_photo',
    'field_cv_document',
    'field_declaration_interest',
  ] as $field_name) {
    if (isset($form[$field_name])) {
      $form[$field_name]['#states']['visible'][$enable_modal_selector] = ['checked' => TRUE];
    }
  }
}

/**
 * Implements hook_node_insert().
 *
 * Invalidates the organigram node list tag so any cached organigram that
 * could include the new node is rebuilt on the next request.
 */
function organigram_node_insert(NodeInterface $node): void {
  if ($node->bundle() === 'organigram_node') {
    Cache::invalidateTags(['node_list:organigram_node']);
  }
}

/**
 * Implements hook_node_update().
 *
 * The node's own cache tags (node:NID) are invalidated automatically by core.
 * We additionally invalidate the list tag so ancestor-rooted organigrams that
 * embed this node are also rebuilt.
 */
function organigram_node_update(NodeInterface $node): void {
  if ($node->bundle() === 'organigram_node') {
    Cache::invalidateTags(['node_list:organigram_node']);
  }
}

/**
 * Implements hook_node_delete().
 *
 * Core invalidates the node's own cache tags on delete. The list tag
 * invalidation here ensures ancestor-rooted organigrams remove the deleted
 * node from any cached output.
 */
function organigram_node_delete(NodeInterface $node): void {
  if ($node->bundle() === 'organigram_node') {
    Cache::invalidateTags(['node_list:organigram_node']);
  }
}

/**
 * Implements hook_ENTITY_TYPE_insert() for organigram_node_type.
 *
 * Invalidates the config-entity list tag so all organigram displays pick up
 * the new node type on their next render.
 */
function organigram_organigram_node_type_insert(EntityInterface $entity): void {
  Cache::invalidateTags(['config:organigram.organigram_node_type_list']);
}

/**
 * Implements hook_ENTITY_TYPE_update() for organigram_node_type.
 *
 * The entity's own config cache tag is invalidated automatically by core.
 * We also invalidate the list tag so organigrams that reference this type
 * through their visuals are flushed.
 */
function organigram_organigram_node_type_update(EntityInterface $entity): void {
  Cache::invalidateTags(['config:organigram.organigram_node_type_list']);
}

/**
 * Implements hook_ENTITY_TYPE_delete() for organigram_node_type.
 *
 * Ensures all cached organigram output that referenced the deleted type is
 * invalidated immediately.
 */
function organigram_organigram_node_type_delete(EntityInterface $entity): void {
  Cache::invalidateTags(['config:organigram.organigram_node_type_list']);
}
