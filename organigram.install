<?php

/**
 * @file
 * Install, update and uninstall functions for the Organigram module.
 */

/**
 * Implements hook_install().
 */
function organigram_install(): void {
  \Drupal::messenger()->addStatus(t(
    'Organigram installed. Visit <a href=":url">Organigram Node Types</a> to manage node visual styles.',
    [':url' => '/admin/structure/organigram-node-type']
  ));
}
